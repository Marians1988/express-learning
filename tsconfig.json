{
  "compilerOptions": {
    "target": "ES2020",                  
    "module": "node20",                  
    "moduleResolution": "NodeNext",   
    "esModuleInterop": true,             
    "forceConsistentCasingInFileNames": true,
    "strict": true,                      
    "skipLibCheck": true,                
    "outDir": "./dist",                  
    "rootDir": "./src",                
    "resolveJsonModule": true,           
    "allowSyntheticDefaultImports": true
  },
}